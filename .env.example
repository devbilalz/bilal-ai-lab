# Canonical public origin used for SEO metadata, sitemap.xml, robots.txt,
# Open Graph URLs and JSON-LD. Set this to the real domain once it is live.
# On Vercel you can leave it unset and the app falls back to the deployment's
# own URL automatically, but a stable custom domain is strongly recommended.
NEXT_PUBLIC_SITE_URL=https://bilalzahid.dev
